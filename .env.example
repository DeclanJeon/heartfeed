QDRANT_URL=http://localhost:6333
DATEWISE_COLLECTION_NAME=datewise_transcripts
DATEWISE_AUTO_CATEGORY_FILTERS=false
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# DeepSeek paid primary (OpenAI-compatible)
LLM_PROVIDER=openai
LLM_API_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_FALLBACK_API_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=

# Free paths: keep false for Rescue/prod
LLM_ALLOW_FREE_LLM=false

# Optional Nous (dev only; free models blocked when ALLOW_FREE_LLM=false)
LLM_NOUS_MODEL=tencent/hy3:free
LLM_NOUS_AUTH_PATH=~/.hermes/auth.json

# Rescue / BRT-14
DATEWISE_PRODUCT_MODE=rescue_brt14
DATEWISE_APP_ENV=dev
DATEWISE_ALLOW_GENERAL=false
DATEWISE_MAX_OUTPUT_TOKENS=2500
DATEWISE_GENERATION_CONCURRENCY=4
