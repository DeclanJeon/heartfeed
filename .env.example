QDRANT_URL=http://localhost:6333
DATEWISE_COLLECTION_NAME=datewise_transcripts
DATEWISE_AUTO_CATEGORY_FILTERS=false
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

LLM_API_URL=https://api.xiaomimimo.com/v1
LLM_API_KEY=
LLM_MODEL=mimo-v2.5
LLM_FALLBACK_API_URL=https://openrouter.ai/api/v1
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=google/gemma-4-31b-it:free

# --- LLM provider selection ---
# "openai"  -> use LLM_API_KEY against any OpenAI-compatible endpoint (default)
# "nous"    -> reuse the Hermes operational agent's NousResearch OAuth token.
#              No static key needed; the token is read from the Hermes auth.json
#              and refreshed automatically (≈1h expiry). Uses the fast
#              stepfun/step-3.7-flash:free model by default.
LLM_PROVIDER=openai
LLM_NOUS_MODEL=stepfun/step-3.7-flash:free
LLM_NOUS_AUTH_PATH=~/.hermes/auth.json
